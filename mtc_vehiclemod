local vehicles = game:GetService("ReplicatedStorage").NewDriveData.Vehicles
local selected = nil
local forward = 0
local reverse = 0
local maxforwardgear = 0
local maxreversegear = 0

local function updatevalues()
    if not selected then return end
    local config = require(vehicles:FindFirstChild(selected))
    forward = config.ForwardSpeed
    reverse = config.ReverseSpeed
    maxforwardgear = config.MaxForwardGear
    maxreversegear = config.MaxReverseGear
    forwardvalue.Text = tostring(forward)
    reversevalue.Text = tostring(reverse)
    maxforwardvalue.Text = tostring(maxforwardgear)
    maxreversevalue.Text = tostring(maxreversegear)
    sliderfill.Size = UDim2.new(forward / 1000, 0, 1, 0)
    reversesliderfill.Size = UDim2.new(reverse / 200, 0, 1, 0)
    maxforwardsliderfill.Size = UDim2.new(maxforwardgear / 20, 0, 1, 0)
    maxreversesliderfill.Size = UDim2.new(maxreversegear / 20, 0, 1, 0)
end

local function apply()
    if not selected then return end
    local config = require(vehicles:FindFirstChild(selected))
    config.ForwardSpeed = forward
    config.ReverseSpeed = reverse
    config.MaxForwardGear = maxforwardgear
    config.MaxReverseGear = maxreversegear
end

local vehiclelist = {}
for i, v in pairs(vehicles:GetChildren()) do
    table.insert(vehiclelist, v.Name)
end

local dropdownopen = false

vehicledropdown.MouseButton1Click:Connect(function()
    dropdownopen = not dropdownopen
    dropdownlist.Visible = dropdownopen
    if dropdownopen then
        for i, child in pairs(scrolling:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end
        local y = 0
        for i, name in pairs(vehiclelist) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 25)
            btn.Position = UDim2.new(0, 0, 0, y)
            btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            btn.BackgroundTransparency = 0.2
            btn.Text = name
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.TextSize = 14
            btn.Font = Enum.Font.Gotham
            btn.Parent = scrolling
            btn.ZIndex = 10
            btn.MouseButton1Click:Connect(function()
                selected = name
                vehicledropdown.Text = name
                dropdownlist.Visible = false
                dropdownopen = false
                updatevalues()
            end)
            y = y + 25
        end
        scrolling.CanvasSize = UDim2.new(0, 0, 0, y)
    end
end)

local forwarddragging = false
forwardslider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        forwarddragging = true
        local pos = math.clamp((input.Position.X - forwardslider.AbsolutePosition.X) / forwardslider.AbsoluteSize.X, 0, 1)
        local value = math.round(0 + (1000 - 0) * pos)
        sliderfill.Size = UDim2.new(pos, 0, 1, 0)
        forwardvalue.Text = tostring(value)
        forward = value
    end
end)
forwardslider.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        forwarddragging = false
    end
end)
